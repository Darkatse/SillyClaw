{
  "name": "sillyclaw",
  "version": "0.3.0",
  "description": "SillyTavern preset importer + roleplay prompt overlays for OpenClaw.",
  "license": "MIT",
  "type": "module",
  "openclaw": {
    "extensions": ["./index.ts"]
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.json && tsc -p tsconfig.test.json",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "prepublishOnly": "npm run typecheck && npm test"
  },
  "files": [
    "index.ts",
    "src",
    "types",
    "openclaw.plugin.json",
    "README.md",
    "README.zh-CN.md",
    "LICENSE",
    "docs"
  ],
  "publishConfig": {
    "access": "public"
  },
  "keywords": ["openclaw", "openclaw-plugin", "sillytavern", "prompt", "roleplay"],
  "devDependencies": {
    "@types/node": "^22.13.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
