{
  "name": "sillyclaw",
  "version": "0.1.0",
  "private": true,
  "description": "SillyTavern preset importer + roleplay prompt overlays for OpenClaw.",
  "type": "module",
  "openclaw": {
    "extensions": ["./index.ts"]
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.json && tsc -p tsconfig.test.json",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
